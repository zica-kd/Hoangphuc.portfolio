  document.getElementById('contactEmail').textContent = c('contact_email');
  document.getElementById('contactPhone').textContent = c('contact_phone');

  // Font
  const font = c('font_family');
  const baseSize = c('font_size');
  document.body.style.fontFamily = `${font}, Outfit, Time newroman`;
  heroName.style.fontSize = `${baseSize * 3}px`;
  document.getElementById('heroSubtitle').style.fontSize = `${baseSize * 1.25}px`;
  document.getElementById('heroDesc').style.fontSize = `${baseSize}px`;

