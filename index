.interactive-orb {
  position: fixed;
  pointer-events: none;
  z-index: 1;
  width: 100px;
  height: 100px;
  background: radial-gradient(circle at 30% 30%, rgba(168,85,247,0.8), rgba(59,130,246,0.2));
  border-radius: 50%;
  box-shadow: 0 0 60px rgba(168,85,247,0.6), inset -2px -2px 5px rgba(0,0,0,0.5);
  filter: blur(1px);
}

/* Cyber grid effect */
.cyber-grid {
  position: fixed;
  width: 100%;
  height: 100%;
  background-image: 
    linear-gradient(0deg, transparent 24%, rgba(168,85,247,0.05) 25%, rgba(168,85,247,0.05) 26%, transparent 27%, transparent 74%, rgba(168,85,247,0.05) 75%, rgba(168,85,247,0.05) 76%, transparent 77%, transparent),
    linear-gradient(90deg, transparent 24%, rgba(168,85,247,0.05) 25%, rgba(168,85,247,0.05) 26%, transparent 27%, transparent 74%, rgba(168,85,247,0.05) 75%, rgba(168,85,247,0.05) 76%, transparent 77%, transparent);
  background-size: 100px 100px;
  animation: grid-perspective 20s linear infinite;
  pointer-events: none;
  z-index: 1;
  opacity: 0.4;
  perspective: 1000px;
}

@keyframes grid-perspective {
  0% {
    background-position: 0 0;
    transform: perspective(1000px) rotateX(0deg);
  }
  50% {
    transform: perspective(1000px) rotateX(2deg);
  }
  100% {
    background-position: 0 100px;
    transform: perspective(1000px) rotateX(0deg);
  }
}

/* Aurora borealis effect */
.aurora {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.aurora::before {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  background: linear-gradient(90deg,
    transparent,
    rgba(168,85,247,0.1) 20%,
    rgba(99,102,241,0.1) 40%,
    rgba(59,130,246,0.1) 50%,
    rgba(6,182,212,0.1) 60%,
    rgba(99,102,241,0.1) 80%,
    transparent
  );
  animation: aurora-wave 8s ease-in-out infinite;
  transform: skewY(-10deg);
}

@keyframes aurora-wave {
  0%, 100% {
    transform: skewY(-10deg) translateX(-10%);
  }
  50% {
    transform: skewY(-10deg) translateX(10%);
  }
}

/* Hover glow effect */
.glow-hover {
  transition: all 0.3s ease;
}

.glow-hover:hover {
  box-shadow: 0 0 30px rgba(168,85,247,0.4), inset 0 0 30px rgba(168,85,247,0.1);
