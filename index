<!doctype html>
<html lang="vi" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hoàng Phúc Portfolio</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <style>
html{scroll-behavior:smooth;height:100%}
body{height:100%;margin:0;font-family:'Times New Roman',Georgia,serif;overflow-x:hidden}
*{box-sizing:border-box}

:root{
--bg:#0a1410;--surface:rgba(34,197,94,0.12);--text:#f0fdf4;
--primary:#22c55e;--secondary:#10b981;
}

.app-wrapper{height:100%;overflow-y:auto;overflow-x:hidden;background:var(--bg);color:var(--text);position:relative;z-index:10}

/* Glassmorphism */
.glass{background:rgba(255,255,255,0.05);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.08);border-radius:20px}

/* Glow avatar */
.avatar-glow{
  width:160px;height:160px;border-radius:50%;
  background:linear-gradient(135deg,#22c55e,#10b981,#06b6d4);
  padding:4px;position:relative;
  animation:glow-pulse 3s ease-in-out infinite;
}
.avatar-glow::after{
  content:'';position:absolute;inset:-8px;border-radius:50%;
  background:linear-gradient(135deg,#22c55e,#10b981,#06b6d4);
  filter:blur(20px);opacity:0.5;z-index:-1;
}
@keyframes glow-pulse{0%,100%{filter:brightness(1)}50%{filter:brightness(1.2)}}

.avatar-inner{width:100%;height:100%;border-radius:50%;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:3.5rem;font-weight:800;color:#a855f7}

/* Blob shapes */
.blob{position:absolute;border-radius:50%;filter:blur(80px);opacity:0.3;pointer-events:none}
.blob-1{width:400px;height:400px;background:#22c55e;top:-100px;left:-100px}
.blob-2{width:300px;height:300px;background:#10b981;bottom:-50px;right:-50px}
.blob-3{width:250px;height:250px;background:#06b6d4;top:50%;left:60%}

/* Skill bar */
.skill-bar{height:8px;border-radius:99px;background:rgba(255,255,255,0.08);overflow:hidden}
.skill-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,#22c55e,#10b981);transition:width 1.2s cubic-bezier(.22,1,.36,1)}

/* Timeline */
.timeline-line{position:absolute;left:20px;top:0;bottom:0;width:2px;background:linear-gradient(180deg,#22c55e,#10b981,transparent)}
.timeline-dot{width:12px;height:12px;border-radius:50%;background:linear-gradient(135deg,#22c55e,#10b981);border:2px solid var(--bg);position:absolute;left:15px;top:6px;z-index:2}

/* Card hover */
.project-card{transition:transform .4s cubic-bezier(.22,1,.36,1),box-shadow .4s ease;text-decoration:none;display:block;color:inherit}
.project-card:hover{transform:translateY(-8px);box-shadow:0 20px 60px rgba(168,85,247,0.15)}
.project-card .card-overlay{opacity:0;transition:opacity .3s ease}
.project-card:hover .card-overlay{opacity:1}

/* CTA buttons */
.btn-primary{
  background:linear-gradient(135deg,#22c55e,#10b981);
  padding:12px 28px;border-radius:99px;font-weight:600;color:#fff;
  transition:all .3s ease;border:none;cursor:pointer;display:inline-flex;align-items:center;gap:8px;
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(34,197,94,0.4)}
.btn-outline{
  padding:12px 28px;border-radius:99px;font-weight:600;color:#d1fae5;
  border:1.5px solid rgba(255,255,255,0.2);background:transparent;
  transition:all .3s ease;cursor:pointer;display:inline-flex;align-items:center;gap:8px;
}
.btn-outline:hover{border-color:#22c55e;background:rgba(34,197,94,0.1);transform:translateY(-2px)}

/* Section reveal */
.reveal-section{opacity:0;transform:translateY(40px);transition:opacity .8s ease,transform .8s ease}
.reveal-section.visible{opacity:1;transform:translateY(0)}

/* Filter buttons */
.filter-btn{padding:8px 20px;border-radius:99px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--text);cursor:pointer;transition:all .3s ease;font-family:'Outfit',sans-serif;font-size:14px}
.filter-btn.active,.filter-btn:hover{background:linear-gradient(135deg,#22c55e,#10b981);border-color:transparent;color:#fff}

/* Input style */
.form-input{
  width:100%;padding:14px 20px;border-radius:14px;border:1px solid rgba(255,255,255,0.1);
  background:rgba(255,255,255,0.04);color:var(--text);font-family:'Outfit',sans-serif;font-size:15px;
  transition:border-color .3s ease,box-shadow .3s ease;outline:none;
}
.form-input:focus{border-color:#22c55e;box-shadow:0 0 20px rgba(34,197,94,0.15)}
.form-input::placeholder{color:rgba(255,255,255,0.3)}

/* Nav */
.nav-link{position:relative;color:rgba(255,255,255,0.6);transition:color .3s ease}
.nav-link:hover{color:#fff}
.nav-link::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:linear-gradient(90deg,#22c55e,#10b981);transition:width .3s ease}
.nav-link:hover::after{width:100%}

/* Scrollbar */
.app-wrapper::-webkit-scrollbar{width:6px}
.app-wrapper::-webkit-scrollbar-track{background:transparent}
.app-wrapper::-webkit-scrollbar-thumb{background:rgba(168,85,247,0.3);border-radius:99px}

/* Stat card */
.stat-card{text-align:center;padding:24px 16px}
.stat-number{font-size:2rem;font-weight:800;background:linear-gradient(135deg,#ff6b6b,#ffa500);-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* Circular progress */
.circular-progress{position:relative;width:80px;height:80px}
.circular-progress svg{transform:rotate(-90deg)}
.circular-progress .progress-text{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px}

/* Enhanced animations */
@keyframes float-in {
  0% { opacity: 0; transform: translateY(20px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes slide-right {
  0% { opacity: 0; transform: translateX(-40px); }
  100% { opacity: 1; transform: translateX(0); }
}

@keyframes glow-rotate {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes float {
  0%, 100% { transform: translateY(-10px); }
  50% { transform: translateY(10px); }
}

@keyframes pulse-border {
  0%, 100% { border-color: rgba(168,85,247,0.3); box-shadow: 0 0 20px rgba(168,85,247,0.1); }
  50% { border-color: rgba(168,85,247,0.8); box-shadow: 0 0 40px rgba(168,85,247,0.3); }
}

.float-animation { animation: float 3s ease-in-out infinite; }
.pulse-border-animation { animation: pulse-border 2.5s ease-in-out infinite; }

@keyframes gradient-flow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes hero-name-flow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes hero-name-pulse {
  0%, 100% { filter: drop-shadow(0 0 30px rgba(168,85,247,0.4)) drop-shadow(0 0 60px rgba(236,72,153,0.2)); }
  50% { filter: drop-shadow(0 0 50px rgba(168,85,247,0.7)) drop-shadow(0 0 100px rgba(236,72,153,0.5)); }
}

/* Gradient text effect */
.gradient-text {
  background: linear-gradient(135deg,#22c55e,#10b981,#06b6d4,#22c55e);
  background-size: 300% 300%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: glow-rotate 4s ease infinite;
}

/* Neon border effect */
.neon-card {
  border: 2px solid rgba(34,197,94,0.3);
  position: relative;
  overflow: hidden;
}

.neon-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg,transparent,rgba(34,197,94,0.2),transparent);
  animation: slide 3s infinite;
}

@keyframes slide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* Hover effects */
.card-shine:hover::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  animation: shine 0.5s;
}

@keyframes shine {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* Animated background grid */
.bg-grid {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    linear-gradient(0deg, transparent 24%, rgba(34,197,94,.1) 25%, rgba(34,197,94,.1) 26%, transparent 27%, transparent 74%, rgba(34,197,94,.1) 75%, rgba(34,197,94,.1) 76%, transparent 77%, transparent),
    linear-gradient(90deg, transparent 24%, rgba(34,197,94,.1) 25%, rgba(34,197,94,.1) 26%, transparent 27%, transparent 74%, rgba(34,197,94,.1) 75%, rgba(34,197,94,.1) 76%, transparent 77%, transparent);
  background-size: 50px 50px;
  animation: grid-drift 20s linear infinite;
  pointer-events: none;
  z-index: 1;
  opacity: 0.3;
}

@keyframes grid-drift {
  0% { transform: translateY(0) translateX(0); }
  100% { transform: translateY(50px) translateX(50px); }
}

/* Floating particles */
.particle {
  position: fixed;
  pointer-events: none;
  z-index: 1;
  border-radius: 50%;
}

.particle-1 { width: 8px; height: 8px; background: rgba(34,197,94,0.3); animation: float-particle 15s infinite ease-in-out; left: 10%; top: 20%; }
.particle-2 { width: 6px; height: 6px; background: rgba(16,185,129,0.3); animation: float-particle 18s infinite ease-in-out 2s; left: 80%; top: 60%; }
.particle-3 { width: 10px; height: 10px; background: rgba(6,182,212,0.2); animation: float-particle 20s infinite ease-in-out 4s; left: 20%; top: 80%; }
.particle-4 { width: 7px; height: 7px; background: rgba(34,197,94,0.3); animation: float-particle 17s infinite ease-in-out 1s; left: 70%; top: 15%; }
.particle-5 { width: 5px; height: 5px; background: rgba(16,185,129,0.25); animation: float-particle 19s infinite ease-in-out 3s; left: 40%; top: 90%; }

@keyframes float-particle {
  0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
  25% { transform: translateY(-50px) translateX(30px); opacity: 0.6; }
  50% { transform: translateY(-100px) translateX(-30px); opacity: 0.3; }
  75% { transform: translateY(-50px) translateX(50px); opacity: 0.5; }
}

/* Decorative elements */
.accent-line {
  height: 2px;
  background: linear-gradient(90deg,#22c55e,#10b981,transparent);
  margin: 16px 0;
}

/* Animated section divider */
.section-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(34,197,94,0.5), transparent);
  margin: 60px 0;
  animation: pulse-line 3s ease-in-out infinite;
}

@keyframes pulse-line {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

/* Floating background shapes - animated */
.float-shape {
  position: fixed;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.15;
  pointer-events: none;
  z-index: 0;
}

.float-shape-1 {
  width: 300px;
  height: 300px;
  background: #22c55e;
  top: 10%;
  left: 5%;
  animation: float-shape-move 30s ease-in-out infinite;
}

.float-shape-2 {
  width: 250px;
  height: 250px;
  background: #10b981;
  top: 50%;
  right: 10%;
  animation: float-shape-move 40s ease-in-out infinite reverse;
}

.float-shape-3 {
  width: 200px;
  height: 200px;
  background: #06b6d4;
  bottom: 10%;
  left: 30%;
  animation: float-shape-move 35s ease-in-out infinite;
}

@keyframes float-shape-move {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(40px, -50px); }
  50% { transform: translate(-30px, 60px); }
  75% { transform: translate(50px, 30px); }
}

/* Text shimmer effect */
.shimmer-text {
  background: linear-gradient(90deg, #a855f7, #3b82f6, #a855f7);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: shimmer 3s ease infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Hologram effect */
.hologram {
  position: relative;
  display: inline-block;
}

.hologram::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(45deg, #a855f7, #3b82f6, #06b6d4, #a855f7);
  background-size: 300% 300%;
  border-radius: inherit;
  animation: hologram-glow 4s ease infinite;
  opacity: 0.5;
  z-index: -1;
}

@keyframes hologram-glow {
  0% { background-position: 0% 50%; filter: blur(8px); opacity: 0.3; }
  50% { background-position: 100% 50%; filter: blur(12px); opacity: 0.7; }
  100% { background-position: 0% 50%; filter: blur(8px); opacity: 0.3; }
}

/* Magnetic hover effect */
.magnetic-item {
  position: relative;
  cursor: pointer;
}

/* Particle burst effect */
@keyframes particle-burst {
  0% {
    opacity: 1;
    transform: translate(0, 0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(var(--tx), var(--ty)) scale(0);
  }
}

.particle-burst {
  position: fixed;
  pointer-events: none;
  z-index: 999;
  animation: particle-burst 0.8s ease-out forwards;
  box-shadow: 0 0 15px rgba(168,85,247,0.8);
}

/* Staggered entrance */
.stagger-enter {
  animation: stagger-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  opacity: 0;
}

@keyframes stagger-in {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Project card entrance */
.project-card {
  animation: card-pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes card-pop {
  0% {
    opacity: 0;
    transform: scale(0.85) translateY(20px);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* Smooth section transitions */
.section-fade-in {
  animation: fade-in-section 0.8s ease-out forwards;
}

@keyframes fade-in-section {
  0% {
    opacity: 0;
    transform: translateY(40px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Smooth skill bar fill */
.skill-bar-enhanced .fill {
  transition: width 1.8s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Enhanced button interaction */
.btn-primary, .btn-outline {
  position: relative;
  overflow: hidden;
}

.btn-primary::after, .btn-outline::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.btn-primary:active::after, .btn-outline:active::after {
  animation: ripple 0.6s ease-out;
}

@keyframes ripple {
  0% {
    width: 0;
    height: 0;
    opacity: 1;
  }
  100% {
    width: 300px;
    height: 300px;
    opacity: 0;
  }
}

/* Input focus glow */
.form-input {
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.form-input:focus {
  transform: translateY(-2px);
  box-shadow: 0 0 30px rgba(168,85,247,0.2), inset 0 0 20px rgba(168,85,247,0.05);
}

/* Smooth stat number animation */
@keyframes stat-count {
  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}

.stat-number {
  animation: stat-count 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Timeline item entrance */
.timeline-item {
  opacity: 0;
  animation: timeline-slide 0.6s ease-out forwards;
}

@keyframes timeline-slide {
  0% {
    opacity: 0;
    transform: translateX(-30px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

/* Experience card hover effect */
.exp-card {
  transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

.exp-card:hover {
  transform: translateX(8px);
  box-shadow: 0 20px 60px rgba(168,85,247,0.2);
}

/* Contact info hover pulse */
.contact-item {
  transition: all 0.3s ease;
}

.contact-item:hover {
  transform: translateX(4px);
}

.contact-item:hover .contact-icon {
  animation: icon-pulse 0.4s ease-out;
}

@keyframes icon-pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

/* Smooth nav underline */
.nav-link::after {
  transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Filter button transition */
.filter-btn {
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.filter-btn:hover {
  transform: translateY(-2px);
}

.filter-btn.active {
  animation: btn-activate 0.4s ease-out;
}

@keyframes btn-activate {
  0% {
    transform: scale(0.95);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* Smooth scrollbar animation */
.app-wrapper::-webkit-scrollbar-thumb {
  transition: background 0.3s ease;
}

.app-wrapper::-webkit-scrollbar-thumb:hover {
  background: rgba(168,85,247,0.5);
}

/* Cyberpunk scan lines */
.scanline {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(168,85,247,0.5), transparent);
  animation: scan 8s linear infinite;
  pointer-events: none;
  z-index: 2;
}

@keyframes scan {
  0% { top: 0%; }
  100% { top: 100%; }
}

/* Neon text glow */
.neon-text {
  text-shadow: none;
}

@keyframes neon-flicker {
  0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
    text-shadow: none;
  }
  20%, 24%, 55% {
    text-shadow: none;
  }
}

/* Liquid morphing shape */
.liquid-shape {
  position: fixed;
  filter: blur(50px);
  opacity: 0.2;
  pointer-events: none;
  z-index: 0;
  mix-blend-mode: screen;
}

.liquid-1 {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle at 30% 40%, #a855f7 0%, transparent 60%);
  top: 5%;
  left: 0%;
  animation: liquid-morph-1 15s ease-in-out infinite;
}

.liquid-2 {
  width: 400px;
  height: 400px;
  background: radial-gradient(circle at 70% 60%, #3b82f6 0%, transparent 60%);
  bottom: 5%;
  right: 5%;
  animation: liquid-morph-2 18s ease-in-out infinite;
}

.liquid-3 {
  width: 350px;
  height: 350px;
  background: radial-gradient(circle at 50% 50%, #06b6d4 0%, transparent 60%);
  top: 40%;
  left: 40%;
  animation: liquid-morph-3 20s ease-in-out infinite;
}

@keyframes liquid-morph-1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(50px, -80px) scale(1.1); }
  50% { transform: translate(-40px, 60px) scale(0.95); }
  75% { transform: translate(80px, 40px) scale(1.05); }
}

@keyframes liquid-morph-2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(-60px, 70px) scale(1.05); }
  50% { transform: translate(50px, -50px) scale(0.98); }
  75% { transform: translate(-50px, -60px) scale(1.02); }
}

@keyframes liquid-morph-3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(60px, 50px) scale(0.9); }
  50% { transform: translate(-50px, -70px) scale(1.1); }
  75% { transform: translate(40px, -30px) scale(0.95); }
}

/* Radial energy pulse */
.energy-pulse {
  position: fixed;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(168,85,247,0.4) 0%, rgba(168,85,247,0) 70%);
  pointer-events: none;
  z-index: 1;
}

.pulse-ripple {
  position: absolute;
  border-radius: 50%;
  border: 2px solid #a855f7;
  animation: energy-ripple 1.5s ease-out forwards;
}

@keyframes energy-ripple {
  0% {
    width: 0;
    height: 0;
    opacity: 1;
  }
  100% {
    width: 200px;
    height: 200px;
    opacity: 0;
  }
}

/* Star field background */
.star-field {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
}

.star {
  position: absolute;
  width: 1px;
  height: 1px;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* Glitch effect */
.glitch-text {
  position: relative;
  display: inline-block;
  animation: glitch-anim 2s infinite;
}

.glitch-text::before,
.glitch-text::after {
  content: attr(data-text);
  position: absolute;
  left: 0;
  top: 0;
}

.glitch-text::before {
  animation: glitch-1 0.3s infinite;
  color: #a855f7;
  z-index: -1;
}

.glitch-text::after {
  animation: glitch-2 0.3s infinite;
  color: #3b82f6;
  z-index: -2;
}

@keyframes glitch-anim {
  0% { transform: translate(0); }
  20% { transform: translate(-2px, 2px); }
  40% { transform: translate(-2px, -2px); }
  60% { transform: translate(2px, 2px); }
  80% { transform: translate(2px, -2px); }
  100% { transform: translate(0); }
}

@keyframes glitch-1 {
  0% { clip-path: inset(0 0 0 0); }
  20% { clip-path: inset(0 0 65% 0); }
  40% { clip-path: inset(28% 0 58% 0); }
  60% { clip-path: inset(54% 0 7% 0); }
  80% { clip-path: inset(63% 0 10% 0); }
  100% { clip-path: inset(0 0 0 0); }
}

@keyframes glitch-2 {
  0% { clip-path: inset(0 0 0 0); }
  20% { clip-path: inset(0 0 0 40%); }
  40% { clip-path: inset(37% 0 58% 0); }
  60% { clip-path: inset(3% 0 58% 0); }
  80% { clip-path: inset(22% 0 77% 0); }
  100% { clip-path: inset(0 0 0 0); }
